# Staging Environment Configuration
ENVIRONMENT=staging
AWS_REGION=ap-south-1
STACK_NAME=bharat-sahayak-staging

# API Configuration
API_DOMAIN=staging-api.bharatsahayak.in
FRONTEND_DOMAIN=staging.bharatsahayak.in

# S3 Buckets
FRONTEND_BUCKET=bharat-sahayak-staging-frontend
TEMP_AUDIO_BUCKET=bharat-sahayak-staging-audio-temp

# DynamoDB
DYNAMODB_TABLE=bharat-sahayak-staging-data

# Bedrock Configuration
BEDROCK_MODEL_ID=anthropic.claude-3-sonnet-20240229-v1:0
BEDROCK_MAX_TOKENS=2048

# Rate Limiting
API_RATE_LIMIT=1000
API_BURST_LIMIT=500
PER_IP_RATE_LIMIT=100

# Monitoring
LOG_RETENTION_DAYS=14
ENABLE_DETAILED_METRICS=true

# Feature Flags
ENABLE_VOICE_INPUT=true
ENABLE_VOICE_OUTPUT=true
ENABLE_TRANSLATION=true
